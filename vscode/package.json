{
    "name": "uplink",
    "displayName": "Uplink",
    "description": "Командный мессенджер со звонками, встроенный в VS Code",
    "version": "1.1.1",
    "publisher": "uplink-team",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Other"],
    "activationEvents": ["onStartupFinished"],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "uplink.openChat",
                "title": "Uplink: Открыть чат",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "uplink.sendSnippet",
                "title": "Uplink: Отправить код в чат"
            },
            {
                "command": "uplink.sendFile",
                "title": "Uplink: Отправить файл в чат"
            },
            {
                "command": "uplink.startCall",
                "title": "Uplink: Начать звонок"
            },
            {
                "command": "uplink.disconnect",
                "title": "Uplink: Отключиться"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "uplink.sendSnippet",
                    "when": "editorHasSelection",
                    "group": "uplink"
                }
            ]
        },
        "keybindings": [
            {
                "command": "uplink.openChat",
                "key": "ctrl+shift+u",
                "mac": "cmd+shift+u"
            },
            {
                "command": "uplink.sendSnippet",
                "key": "ctrl+shift+l",
                "mac": "cmd+shift+l",
                "when": "editorTextFocus && editorHasSelection"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "uplink",
                    "title": "Uplink",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "uplink": [
                {
                    "type": "webview",
                    "id": "uplink.chatPanel",
                    "name": "Чат"
                }
            ]
        },
        "configuration": {
            "title": "Uplink",
            "properties": {
                "uplink.serverUrl": {
                    "type": "string",
                    "default": "https://uplink.wh-lab.ru",
                    "description": "URL Uplink-сервера (Matrix homeserver). Используется при первом подключении."
                }
            }
        }
    },
    "scripts": {
        "build:webview": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){const sp=p.join(s,f),dp=p.join(d,f);fs.statSync(sp).isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp)}}; cp('../web/dist','./webview-dist')\"",
        "vscode:prepublish": "npm run build:webview && npm run build",
        "build": "node esbuild.config.mjs --production",
        "watch": "node esbuild.config.mjs --watch",
        "package": "cd ../web && npm run build && cd ../vscode && npm run build:webview && npm run build && npx vsce package"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@vscode/vsce": "^2.22.0",
        "esbuild": "^0.19.0",
        "typescript": "^5.3.0"
    }
}
