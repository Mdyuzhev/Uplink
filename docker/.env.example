# Uplink — переменные окружения
# Скопировать в .env и заполнить реальными значениями

# PostgreSQL
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=<сгенерировать: python3 -c "import secrets; print(secrets.token_urlsafe(24))">

# Synapse server_name (НЕЛЬЗЯ менять после первого запуска!)
SYNAPSE_SERVER_NAME=uplink.wh-lab.ru

# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_API_KEY=<ключ из LiveKit Cloud dashboard>
LIVEKIT_API_SECRET=<секрет из LiveKit Cloud dashboard>

# GitHub Webhook (для автодеплоя)
WEBHOOK_SECRET=<любая случайная строка>

# Bot Service Application Service tokens
# Должны совпадать с appservice-bots.yaml
BOT_AS_TOKEN=<python3 -c "import secrets; print(secrets.token_hex(32))">
BOT_HS_TOKEN=<python3 -c "import secrets; print(secrets.token_hex(32))">

# Synapse admin token (создаётся после первого запуска)
SYNAPSE_ADMIN_TOKEN=

# GIPHY API (необязательно, https://developers.giphy.com/dashboard/)
GIPHY_API_KEY=
