{
  "id": null,
  "uid": "uplink-overview",
  "title": "Uplink Overview",
  "tags": ["uplink"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "System",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RAM Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Disk Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk /",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Services Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Synapse",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"synapse\"}",
          "legendFormat": "Synapse",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "PostgreSQL",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "PostgreSQL",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Botservice",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"botservice\"}",
          "legendFormat": "Botservice",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "LiveKit Token",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"livekit-token\"}",
          "legendFormat": "LiveKit Token",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Synapse Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Synapse Requests/sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(synapse_http_server_requests_received_total[1m])",
          "legendFormat": "{{method}} {{servlet}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Synapse Response Time (p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(synapse_http_server_response_time_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "PostgreSQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "PostgreSQL Connections",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "PostgreSQL Transactions/sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"synapse\"}[1m])",
          "legendFormat": "Commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"synapse\"}[1m])",
          "legendFormat": "Rollbacks/s",
          "refId": "B"
        }
      ]
    }
  ]
}
